{
  "name": "agilix",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight agile project management for Feishu",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:frontend": "pnpm --filter @agilix/frontend dev",
    "dev:backend": "pnpm --filter @agilix/backend dev",
    "build": "pnpm -r build",
    "lint": "eslint \"{packages,apps}/**/*.{ts,tsx}\"",
    "format": "prettier --write \"{packages,apps}/**/*.{ts,tsx,json,css}\"",
    "test": "pnpm --filter \"./apps/*\" --if-present test",
    "ship": "pnpm --filter @agilix/frontend ship",
    "db:migrate:remote": "pnpm --filter @agilix/frontend exec wrangler d1 migrations apply agilix-db --remote",
    "db:generate": "pnpm --filter @agilix/backend db:generate",
    "db:migrate": "pnpm --filter @agilix/backend db:migrate:local",
    "db:seed": "pnpm --filter @agilix/backend db:seed"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
