{
  "name": "@agilix/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "echo 'Backend deploys via Pages Functions. Run pnpm deploy from root.'",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply agilix-v2-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply agilix-v2-db --remote",
    "db:studio": "drizzle-kit studio",
    "db:seed": "wrangler d1 execute agilix-v2-db --local --file=./drizzle/seed.sql",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@agilix/shared": "workspace:*",
    "hono": "^4.6.0",
    "drizzle-orm": "^0.38.0",
    "jose": "^6.0.0",
    "dayjs": "^1.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
